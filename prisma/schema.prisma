generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS — must match your existing code usage
//

enum SceneStatus {
  AWAITING_ACTIONS
  RESOLVING
  RESOLVED
}

enum EventVisibility {
  PUBLIC
  GM_ONLY
  MIXED
}

enum EventType {
  SCENE
  DOWNTIME
  TIMESKIP
  WORLD_EVENT
}

enum UserRole {
  ADMIN
  PLAYER
}

// Phase 8: Communication enums
enum MessageType {
  IN_CHARACTER
  OUT_OF_CHARACTER
  WHISPER
  SYSTEM
}

enum NoteVisibility {
  PRIVATE
  GM
  SHARED
}

// Phase 9: Notification enums
enum NotificationType {
  TURN_REMINDER
  SCENE_CHANGE
  MENTION
  WHISPER_RECEIVED
  NOTE_SHARED
  CAMPAIGN_INVITE
  SCENE_RESOLVED
  AI_RESPONSE_READY
  WORLD_EVENT
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// World Sim Phase 1: deterministic tick-driven state
enum FactionGoal {
  EXPAND
  DEFEND
  ENRICH
  DESTABILIZE_RIVAL
  CONSOLIDATE
}

// World Sim Phase 2: what kind of organization a faction is, independent of
// its goal — a guild and a secret society can both pursue ENRICH, but they
// shouldn't both throw a "Grand Tournament." Drives which bounded ambition
// flavor list the offscreen AI picks from (see ambitionTick.ts).
enum FactionArchetype {
  GENERIC
  SECRET_SOCIETY
  CRIMINAL
  RELIGIOUS
  MILITARY
  CORPORATION
  POLITICAL
}

// World Sim Phase 4: an NPC's standing within a faction they're affiliated
// with (see NPC.factionRole below).
enum FactionRole {
  LEADER
  MEMBER
}

// World Sim Phase 5: see War below.
enum WarStatus {
  ESCALATING
  RESOLVED
}

enum WeatherCondition {
  CLEAR
  CLOUDY
  RAIN
  STORM
  SNOW
  FOG
}

enum WorldEventActorType {
  SYSTEM // autonomous world tick — nobody "did" this, the world just changed
  PLAYER // caused by a player action (consequence extraction)
}

enum WorldEventTargetType {
  NPC
  FACTION
  LOCATION_WEATHER
}

//
// USER & MEMBERSHIP
//

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Payment system - balance stored in cents (e.g., 100 = $1.00)
  balance Int @default(0)

  // Account security: email verification + password reset.
  // Tokens are UUIDs looked up via findFirst on plain indexes — not
  // @unique, because prisma db push conservatively flags adding a unique
  // constraint as potential data loss and fails the deploy guardrail.
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?
  resetToken        String?
  resetTokenExpires DateTime?

  // Phase 9: Online status
  lastSeenAt DateTime?
  isOnline   Boolean   @default(false)

  campaignMemberships CampaignMembership[]
  characters          Character[]
  playerActions       PlayerAction[]
  createInvites       CampaignInvite[]     @relation("InviteCreator")
  diceRolls           DiceRoll[]
  gmClarifications    GmClarification[]

  // Phase 8: Communication
  sentMessages     Message[]    @relation("UserMessages")
  receivedWhispers Message[]    @relation("UserWhispers")
  notes            PlayerNote[] @relation("UserNotes")

  // Phase 9: Notifications
  notifications        Notification[]            @relation("UserNotifications")
  notificationSettings UserNotificationSettings? @relation("UserNotificationSettings")

  @@index([emailVerifyToken])
  @@index([resetToken])
}

model CampaignMembership {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  role       UserRole @default(PLAYER)
  joinedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
}

//
// CAMPAIGN ROOT
//

model Campaign {
  id               String   @id @default(cuid())
  title            String
  description      String?
  universe         String?
  aiSystemPrompt   String   @db.Text
  initialWorldSeed String   @db.Text
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Player-text input moderation strictness (see lib/ai/moderation.ts).
  // "standard" (default) doesn't block plain violence — expected content
  // in a combat RPG. "strict" blocks everything OpenAI's moderation
  // endpoint flags, for campaigns that want a tighter filter.
  contentModerationLevel String @default("standard")

  // Fiction-flavored display names for the 5 fixed PbtA stat keys
  // (cool/hard/hot/sharp/weird — see lib/pbta-moves.ts), generated once at
  // campaign creation alongside the capability scaffold (see
  // lib/ai/worldGenerator.ts). Null falls back to the generic PBTA_STATS
  // labels. Only the label changes — the underlying keys and resolution
  // math are the same for every campaign.
  // Shape: Record<'cool'|'hard'|'hot'|'sharp'|'weird', { label: string; description: string }>
  statLabels Json?

  // Corruption track theme — what "power at a cost" means in THIS
  // universe, generated at creation (see lib/ai/worldExtras.ts). Defined
  // by the fiction's own devil's bargain, never by aesthetics; null means
  // this universe has no such concept and the track is disabled entirely.
  // Shape: { name, description, stages: string[5], bargainGuidance }
  corruptionTheme Json?

  // True while a creation-time lore import + auto-reseed is in flight —
  // the campaign is unplayable (no characters, no scenes) until the world
  // has finished becoming its canon self, so a mid-import character can't
  // flip the reseed into additive mode. Cleared by the worker when the
  // reseed finishes (or the import permanently fails), with a stale-flag
  // self-heal in lib/lore/seedingGate.ts so a dead worker can never lock
  // a campaign forever.
  pendingWorldSeed Boolean @default(false)

  // #13 first-party templates: which static template (campaign-templates.ts)
  // this campaign was created from, if any — a compile-time id, not a DB
  // relation, since templates are TypeScript objects. Lets a template's
  // startingDebtTemplates be applied when each character joins (Debt rows
  // need a real characterId, which doesn't exist yet at campaign creation).
  templateId String?

  // Phase 9: Campaign notification settings
  mentionsEnabled     Boolean @default(true)
  soundEffectsEnabled Boolean @default(true)

  memberships CampaignMembership[]
  characters  Character[]
  npcs        NPC[]
  factions    Faction[]
  locations   Location[]
  clocks      Clock[]
  scenes      Scene[]
  timeline    TimelineEvent[]
  worldMeta   WorldMeta?
  invites     CampaignInvite[]
  moves       Move[]
  diceRolls   DiceRoll[]
  gmClarifications GmClarification[]

  // Phase 8: Communication
  messages Message[]    @relation("CampaignMessages")
  notes    PlayerNote[] @relation("CampaignNotes")

  // Phase 9: Notifications
  notifications Notification[] @relation("CampaignNotifications")
  turnTracker   TurnTracker[]  @relation("CampaignTurnTracker")

  // Campaign Memory (RAG System)
  memories CampaignMemory[]

  // World Sim: persisted event stream
  worldEvents WorldEvent[]

  // World Sim Phase 5: sustained multi-turn conflicts between factions.
  wars War[]

  // Knowledge-relative capabilities: this universe's latent systems
  // (magic schools, fighting styles, political arts...) that characters
  // discover and grow into through the fiction.
  capabilities CampaignCapability[]

  // Urban Shadows economy: owed favors between PCs and NPCs/factions.
  debts Debt[]

  // Urban Shadows economy: per-character social position with factions.
  factionStandings FactionStanding[]

  // Lore import: pasted text / URLs / wiki crawls, chunked and embedded for
  // the AI GM to draw on during play (see lib/lore, lib/ai/loreRetrieval.ts).
  loreImportJobs LoreImportJob[]
  loreEntries    LoreEntry[]

  // Quest tracking: named objectives the AI GM opens/progresses/closes
  // through play (quest_changes in world_updates — see lib/game/stateUpdater.ts).
  quests Quest[]

  // Playbook onboarding: 3-5 ready-to-play character archetypes generated
  // for this universe at creation (see lib/ai/worldExtras.ts).
  archetypes CampaignArchetype[]
}

//
// ORIGIN ARCHETYPES — per-universe playbook cards for fast character
// creation. Picking one pre-fills the creation wizard (stats, gear,
// familiarity) and seeds starting ties (a Debt or faction standing) plus
// extra capability glimpses server-side. Purely optional — the blank
// wizard still works, and a campaign whose generation failed simply has
// no cards.
//

model CampaignArchetype {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name        String // "Newly Awakened Outworlder"
  description String @db.Text // 1-2 sentence pitch shown on the card

  originFamiliarity OriginFamiliarity @default(NATIVE)
  // Valid PbtA stat array (sum +2, each -2..+3, at most one >= +2) keyed by
  // the 5 fixed stat keys; null = leave the wizard's defaults alone.
  suggestedStats Json?
  // { weapon, armor, misc, items: [{ name, quantity, tags }] }
  startingGear Json?
  // One starting tie into the living world:
  // { kind: 'debt_owed_by_character' | 'debt_owed_to_character' | 'faction_standing',
  //   counterparty_type: 'npc' | 'faction', counterparty_name, description, standing_value? }
  startingTie Json?
  // Questions shown as backstory guidance when the card is picked.
  backstoryPrompts String[] @default([])
  // CampaignCapability keys to seed as GLIMPSED on top of familiarity seeding.
  glimpseCapabilityKeys String[] @default([])

  createdAt DateTime @default(now())

  @@index([campaignId])
}

//
// QUESTS — named objectives with a lifecycle, tracked from the fiction.
// The AI GM registers a quest when an NPC/faction gives the party a job,
// appends progress beats as scenes resolve, and closes it when the fiction
// settles it. Synced to the wiki's QUEST tab (see sceneResolver.ts).
//

enum QuestStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABANDONED
}

model Quest {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name        String
  description String      @db.Text
  objective   String?     @db.Text // what "done" looks like, in-fiction
  givenBy     String? // NPC or faction name that issued it (free text)
  reward      String? // what was promised, if anything (free text)
  status      QuestStatus @default(ACTIVE)
  // Appended narrative beats, newest last — "Turn 4: found the smuggler's ledger"
  progressLog String?     @db.Text

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([campaignId, status])
}

//
// CAPABILITIES (knowledge-relative character sheets)
//
// The universe has a latent tree of learnable systems. What a character
// SEES of that tree depends on what the fiction has shown them:
//   no row      -> the character doesn't know this exists (sheet: absent)
//   GLIMPSED    -> they know it exists but can't do it (sheet: "???" + hint)
//   UNLOCKED    -> they have it; hidden proficiency grows with use/training
// Raw proficiency numbers never leave the server — players only ever see
// qualitative bands (see proficiencyBand in lib/game/capabilities.ts).
//

enum CapabilityState {
  GLIMPSED
  UNLOCKED
}

// How familiar a character is with this universe's systems at creation.
// Drives initial discovery seeding, not power level: a NATIVE knows the
// scaffold of what exists; an OUTSIDER starts with a nearly blank sheet.
enum OriginFamiliarity {
  NATIVE
  NEWCOMER
  OUTSIDER
}

model CampaignCapability {
  id          String   @id @default(cuid())
  campaignId  String
  key         String // stable slug, e.g. "dark-essence"
  name        String
  description String?
  domain      String // top-level grouping, e.g. "Essence Magic", "Swordplay"
  parentId    String?
  tier        Int      @default(1)
  // Secret branches are hidden even from natives until the fiction
  // reveals them (forbidden schools, lost arts).
  isSecret    Boolean  @default(false)
  // Shadow branch: unlockable only through corruption marks (unlock
  // requires corruption >= tier — see lib/game/capabilities.ts). Set at
  // generation time ONLY for campaigns with a corruption theme; distinct
  // from isSecret because mid-story is_new nodes are born secret without
  // being forbidden.
  isShadow    Boolean  @default(false)
  createdAt   DateTime @default(now())

  campaign        Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parent          CampaignCapability?   @relation("CapabilityTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        CampaignCapability[]  @relation("CapabilityTree")
  characterStates CharacterCapability[]

  @@unique([campaignId, key])
  @@index([campaignId])
}

//
// DEBTS (Urban Shadows economy)
//
// A Debt is one owed favor between a player character and an NPC or
// faction, in either direction. It's the AI GM's currency for
// consequences and leverage: incurred when the fiction earns it, called
// in later as pressure, resolved when honored (or refused — which has its
// own costs). Rendered diegetically on the sheet ("Lord Kessler considers
// you in his debt"), never as a ledger counter.
//

enum DebtDirection {
  OWED_BY_CHARACTER // the PC owes the counterparty
  OWED_TO_CHARACTER // the counterparty owes the PC
}

enum DebtStatus {
  OUTSTANDING
  RESOLVED
}

model Debt {
  id          String @id @default(cuid())
  campaignId  String
  characterId String

  direction        DebtDirection
  counterpartyType String // "npc" | "faction"
  // Resolved entity id when the name matched a known NPC/faction; the
  // denormalized name is authoritative for display either way.
  counterpartyId   String?
  counterpartyName String

  description String // what the favor was — the fiction that created it
  status      DebtStatus @default(OUTSTANDING)
  resolution  String? // how it ended (honored, refused, forgiven...)

  turnCreated  Int       @default(0)
  turnResolved Int?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([characterId, status])
}

//
// FACTION STANDING (Urban Shadows economy)
//
// A character's social position with a faction, -3 (hunted/hated) to +3
// (honored/inner circle). Shifts come from scene outcomes; mechanical
// WEIGHT reads live simulation state at roll time (standing with a
// collapsed faction is worthless, with a war-weakened one worth less) —
// this is how the offscreen tick changes what a player can roll without
// the tick writing standing rows. See lib/game/standing.ts.
//

model FactionStanding {
  id          String @id @default(cuid())
  campaignId  String
  characterId String
  factionId   String
  value       Int    @default(0) // -3..+3

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  faction   Faction   @relation(fields: [factionId], references: [id], onDelete: Cascade)

  @@unique([characterId, factionId])
  @@index([campaignId])
}

model CharacterCapability {
  id           String          @id @default(cuid())
  characterId  String
  capabilityId String
  state        CapabilityState @default(GLIMPSED)
  proficiency  Int             @default(0) // 0-100, hidden from players
  // The character's own vocabulary for this capability while they lack
  // the local frame ("Earth sword forms" before learning local styles).
  framedLabel  String?
  hint         String? // shown on "???" (glimpsed) sheet entries
  source       String? // the fiction that revealed/unlocked it
  usageCount   Int             @default(0)
  // Per-arc growth guardrail (see ARC_LENGTH_TURNS / MAX_GROWTH_PER_ARC).
  growthInArc  Int             @default(0)
  arcStartTurn Int             @default(0)
  unlockedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  character  Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)
  capability CampaignCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([characterId, capabilityId])
  @@index([characterId])
}

//
// CHARACTERS
//

model Character {
  id              String  @id @default(cuid())
  campaignId      String
  userId          String
  name            String
  pronouns        String?
  description     String?
  appearance      String? // Physical appearance
  personality     String? // Personality traits and demeanor
  stats           Json? // For PbtA: {cool: 1, hard: 2, hot: -1, sharp: 1, weird: 0}
  backstory       String?
  goals           String?
  isAlive         Boolean @default(true)
  currentLocation String?
  gmNotes         String?

  // Knowledge-relative sheet: how familiar this character is with the
  // universe's systems at creation (drives capability discovery seeding).
  originFamiliarity OriginFamiliarity @default(NATIVE)

  // PbtA specific fields
  harm       Int      @default(0) // 0-6 harm track
  experience Int      @default(0) // XP counter
  // Corruption marks (0..5) toward this campaign's corruption theme.
  // Only meaningful when Campaign.corruptionTheme is set; never decreases
  // (the whole point is irreversibility) — see lib/game/corruption.ts.
  corruption Int      @default(0)
  // An open corruption bargain narrated to this character last scene —
  // their NEXT action can invoke it for an engine-enforced surge bonus
  // (and the mark). Cleared after that action, accepted or not.
  // Shape: { offer: string, offeredTurn: number }
  pendingBargain Json?
  conditions Json? // { conditions: [{ id, name, category, description, mechanicalEffect?, appliedAt? }] }
  moves      String[] // Character move IDs they've unlocked
  holds      Json? // Temporary holds/forward from moves

  // Organic growth tracking
  statUsage      Json? // { [statKey: string]: { uses: Int, successes: Int, failures: Int } }
  perks          Json? // [{ id, name, description, tags? }]
  advancementLog Json? // { entries: [], totalStatIncreases, totalPerksGained, totalMovesLearned }

  // Inventory and equipment
  inventory Json? // { items: [{ id, name, quantity?, tags? }], slots?: number }
  equipment Json? // { weapon?: {...}, armor?: {...}, misc?: [...] }
  resources Json? // { gold?: number, reputation?: { [factionId: string]: number }, contacts?: string[] }

  // Phase 14: Relationships and consequences (HIDDEN from players)
  relationships Json? // { [entityId: string]: { trust: Int, tension: Int, respect: Int, fear: Int } }
  consequences  Json? // { promises?: string[], debts?: string[], enemies?: string[], longTermThreats?: string[] }

  // Phase 16: Zone-based positioning
  currentZone  String? // "close", "near", "far", "distant"
  zoneMetadata Json? // { customZones?: string[], zoneEffects?: object }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  playerActions PlayerAction[]
  diceRolls     DiceRoll[]
  turnOrders    TurnOrder[]
  gmClarifications GmClarification[]

  // Phase 8: Communication
  messages Message[]    @relation("CharacterMessages")
  notes    PlayerNote[] @relation("CharacterNotes")

  // World Sim Phase 6: factions this PC leads (see Faction.leaderCharacterId).
  ledFactions Faction[] @relation("FactionPCLeader")

  // Knowledge-relative sheet: what this character knows of / can do with
  // the universe's capability tree.
  capabilities CharacterCapability[]

  // Urban Shadows economy: this PC's owed favors, both directions.
  debts Debt[]

  // Urban Shadows economy: social position with each faction (-3..+3).
  factionStandings FactionStanding[]

  @@index([campaignId])
  @@index([userId])
}

//
// NPCs & FACTIONS
//

model NPC {
  id              String  @id @default(cuid())
  campaignId      String
  name            String
  pronouns        String?
  description     String?
  currentLocation String?
  goals           String?
  relationship    String?
  isAlive         Boolean @default(true)
  importance      Int     @default(1)
  gmNotes         String?

  // Fog of war: defaults true so existing/starting-world NPCs and any NPC
  // the AI introduces mid-scene (which is itself the discovery event) stay
  // visible without extra steps. Set false to build an NPC into the world
  // as background lore before the party has any in-fiction way to know
  // about them — see stateUpdater.ts for how it flips back to true, and
  // worldState.ts for where undiscovered NPCs are excluded from the
  // player-facing AI prompt entirely.
  isDiscovered Boolean @default(true)

  // World Sim Phase 1: deterministic tick behavior for major NPCs (importance >= 4)
  currentPlan  String?
  // World Sim Phase 2: how far a major NPC has progressed toward their
  // current `goals` text (0-100). Advances deterministically each tick;
  // reaching 100 completes the goal, emits a MAJOR world event, and clears
  // back to 0 awaiting a new goal (set by the AI via world_updates).
  goalProgress Int     @default(0)

  // PbtA fields for significant NPCs
  threat   String? // Type of threat (warlord, grotesque, landscape, etc)
  impulses String[] // What drives this NPC
  moves    String[] // Custom moves this NPC can trigger

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Phase 8: Communication
  notes PlayerNote[] @relation("NPCNotes")

  // World Sim Phase 4: this NPC's affiliation with a faction, if any — gives
  // a faction actual subjects instead of just abstract stats. A LEADER's
  // death triggers automatic succession (see npcTick.ts); a MEMBER can
  // defect if their faction collapses (see factionTick.ts).
  factionId   String?
  factionRole FactionRole?
  faction     Faction?     @relation("FactionMembers", fields: [factionId], references: [id], onDelete: SetNull)

  // Phase 9: NPC society — individual-level relationships between major
  // NPCs, derived from faction affiliation (same faction = ALLY; rival/ally
  // factions per Faction.relationships = inherited). Shape mirrors
  // Faction.relationships: Record<otherNpcId, { type: 'RIVAL' | 'ALLY';
  // since: number }>. Written by npcSocietyTick.ts; distinct from the
  // `relationship` field above, which is this NPC's stance toward the
  // PLAYER CHARACTERS, not toward other NPCs.
  socialTies Json?

  @@index([campaignId])
  @@index([factionId])
}

model Faction {
  id            String   @id @default(cuid())
  campaignId    String
  name          String
  description   String?
  goals         String?
  resources     Int      @default(50)
  influence     Int      @default(50)
  currentPlan   String?
  threatLevel   Int      @default(1)
  // World Sim Phase 3: written and read by relationshipTick.ts. Shape:
  // Record<otherFactionId, { type: 'RIVAL' | 'ALLY'; since: number }>.
  // Absence of an entry for a given faction means NEUTRAL. Recomputed each
  // tick from both factions' goals/stability, so it evolves on its own as
  // circumstances change rather than being a one-time GM-authored fact.
  relationships Json?
  gmNotes       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // World Sim Phase 1: the 4 tracked simulation fields tick logic reads/writes.
  // Added alongside the legacy fields above rather than renaming them (decided
  // 2026-07-08) - influence/threatLevel/currentPlan stay as-is for existing
  // narration code; `goals` (plural) also stays as flavor text.
  stability Int         @default(50)
  military  Int         @default(50)
  goal      FactionGoal @default(CONSOLIDATE)

  // World Sim Phase 2: see FactionArchetype above.
  archetype FactionArchetype @default(GENERIC)

  // Fog of war: defaults true so existing/starting-world factions and any
  // faction the AI registers mid-scene (the registration IS the discovery
  // event) stay visible without extra steps. Set false to build a faction
  // into the world as background lore/antagonist scheming before the party
  // has any in-fiction way to know it exists — flips back to true only
  // when a *live scene* touches it (see stateUpdater.ts's sceneOrigin
  // param), never from an offscreen background event, so the party can't
  // learn about a hidden faction just because the simulation moved it.
  isDiscovered Boolean @default(true)

  // World Sim Phase 3: false once a faction has collapsed (stability
  // bottomed out) — absorbed by a rival or disbanded into a successor. Kept
  // as a row instead of deleted so its history stays queryable. Excluded
  // from all tick processing once false.
  isActive Boolean @default(true)

  // World Sim Phase 6: set when a player character leads this faction
  // rather than an NPC. A player-led faction still ticks like any other
  // (stats drift, ambitions can trigger, wars can happen) but its `goal`
  // is never overwritten by the automatic reassessment in factionTick.ts —
  // the player's own strategic choice sticks, set through scene
  // resolution's world_updates (see stateUpdater.ts) or the admin panel.
  // At most one leader either way: assigning a PC leader demotes any
  // existing NPC LEADER on this faction to MEMBER.
  leaderCharacterId String?
  leaderCharacter   Character? @relation("FactionPCLeader", fields: [leaderCharacterId], references: [id], onDelete: SetNull)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Phase 8: Communication
  notes PlayerNote[] @relation("FactionNotes")

  // World Sim Phase 2: clocks this faction autonomously spawned while
  // pursuing an ambitious goal (e.g. a tournament, a campaign of conquest).
  spawnedClocks Clock[] @relation("FactionSpawnedClocks")

  // World Sim Phase 3: DESTABILIZE_RIVAL clocks aimed at this faction.
  targetedClocks Clock[] @relation("FactionTargetedClocks")

  // #13 / universal front-style threats concerning this faction, without
  // being its tracked ambition (see Clock.relatedFactionId).
  relatedClocks Clock[] @relation("FactionRelatedClocks")

  // World Sim Phase 4: NPCs affiliated with this faction (leader/members).
  members NPC[] @relation("FactionMembers")

  // World Sim Phase 4: locations this faction controls.
  territories Location[] @relation("FactionTerritories")

  // World Sim Phase 5: sustained conflicts this faction is party to.
  warsAsAttacker    War[]            @relation("WarsAsAttacker")
  warsAsDefender    War[]            @relation("WarsAsDefender")
  // Coalitions: every war this faction is actually fighting in, as either
  // the original attacker/defender or a joined ally — see WarParticipant.
  warParticipations WarParticipant[] @relation("WarParticipations")

  // Urban Shadows economy: character standings with this faction.
  characterStandings FactionStanding[]

  @@index([campaignId])
}

//
// LOCATIONS
//

model Location {
  id           String   @id @default(cuid())
  campaignId   String
  name         String
  description  String?
  locationType String? // town, dungeon, wilderness, building, inn, etc.
  isDiscovered Boolean  @default(true) // false = exists in world but players haven't found it
  gmNotes      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // World Sim Phase 1: persistent weather, updated by the world tick and
  // surfaced to the AI prompt builder so narration references it instead of
  // reinventing it. Not a climate model - one condition + a severity scalar.
  weather          WeatherCondition @default(CLEAR)
  weatherSeverity  Int              @default(1) // 1 (mild) - 5 (extreme)
  weatherUpdatedAt DateTime? // last tick that changed the condition

  // World Sim Phase 4: which faction controls this place, if any — the map
  // EXPAND ambitions and faction collapse actually redraw. isContested is a
  // foothold state: a rival has moved against it but hasn't taken it yet
  // (set by a successful EXPAND against owned land, or a successful
  // DESTABILIZE_RIVAL scheme; cleared when it changes hands).
  ownerFactionId String?
  ownerFaction   Faction? @relation("FactionTerritories", fields: [ownerFactionId], references: [id], onDelete: SetNull)
  isContested    Boolean  @default(false)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, name])
  @@index([campaignId])
  @@index([ownerFactionId])
}

//
// WARS — World Sim Phase 5, with multi-faction coalitions
//
// A sustained multi-turn conflict, distinct from a one-shot ambition Clock.
// Declared deterministically when two rival factions are both militarily
// strong AND there's already contested territory between them (see
// warTick.ts) — war is the escalation of a contest, not a random event.
// Each tick while ESCALATING, momentum shifts based on the two sides'
// relative military strength (plus a small deterministic variance) and both
// sides take attrition losses regardless of who's winning. Resolves once
// momentum is decisive or the war has dragged on long enough to call a
// stalemate, at which point the contested territory's fate is settled.
//
// Coalitions: a war always DECLARES as strictly 1v1 (attackerFactionId vs
// defenderFactionId, unchanged) — coalitions grow FROM there, not at
// declaration. Each tick, a side's existing ALLY factions (see
// Faction.relationships) can be pulled in as additional WarParticipant rows
// if they're strong enough and not already committed to any other war. This
// reuses the ALLY relationship type that Phase 3 already computes but never
// gave any mechanical weight to. Momentum/attrition/resolution operate on
// the whole side (sum of all living participants' military, attrition paid
// by every living participant), but the contested territory prize still
// goes only to the original attackerFactionId — an ally fighting alongside
// doesn't inherit land it never personally claimed.

enum WarSide {
  ATTACKER
  DEFENDER
}

model War {
  id         String @id @default(cuid())
  campaignId String

  name                String
  attackerFactionId   String
  defenderFactionId   String
  contestedLocationId String? // the specific prize this war is over, if any

  // -100 (total defender advantage) .. +100 (total attacker advantage).
  momentum Int       @default(0)
  status   WarStatus @default(ESCALATING)
  // Set only once resolved: 'attacker' | 'defender' | 'stalemate'.
  outcome  String?

  startedTurn  Int
  resolvedTurn Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign     Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  attacker     Faction          @relation("WarsAsAttacker", fields: [attackerFactionId], references: [id], onDelete: Cascade)
  defender     Faction          @relation("WarsAsDefender", fields: [defenderFactionId], references: [id], onDelete: Cascade)
  // Every faction actually fighting in this war, both sides — including the
  // original attacker/defender (given their own rows at declaration time),
  // so all war-math can read participants uniformly instead of special-
  // casing "the primary pair plus any extras."
  participants WarParticipant[]

  @@index([campaignId])
  @@index([attackerFactionId])
  @@index([defenderFactionId])
}

model WarParticipant {
  id         String  @id @default(cuid())
  warId      String
  factionId  String
  side       WarSide
  joinedTurn Int

  war     War     @relation(fields: [warId], references: [id], onDelete: Cascade)
  faction Faction @relation("WarParticipations", fields: [factionId], references: [id], onDelete: Cascade)

  @@unique([warId, factionId])
  @@index([warId])
  @@index([factionId])
}

//
// CLOCKS — FULL feature version
//

model Clock {
  id           String   @id @default(cuid())
  campaignId   String
  name         String
  description  String?
  currentTicks Int      @default(0) // required by worldTurn + stateUpdater
  maxTicks     Int      @default(4) // required by code
  category     String?
  isHidden     Boolean  @default(false)
  consequence  String? // triggered result
  gmNotes      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Set the first (and only the first) time checkAndResolveCompletedClocks
  // processes this clock after currentTicks reaches maxTicks. Without this,
  // a completed clock would be re-detected as "just completed" on every
  // subsequent turn forever, since nothing else removes or advances it past
  // maxTicks — re-firing its completion event and (for ambition clocks)
  // re-applying faction stat deltas indefinitely.
  resolvedAt DateTime?

  // World Sim Phase 2: set when a faction autonomously spawned this clock
  // while pursuing an ambitious goal, rather than a GM creating it by hand.
  sourceFactionId String?
  sourceFaction   Faction? @relation("FactionSpawnedClocks", fields: [sourceFactionId], references: [id], onDelete: SetNull)

  // World Sim Phase 3: set when this ambition is a DESTABILIZE_RIVAL clock
  // aimed at a specific rival (see relationshipTick.ts) — lets
  // resolveCompletedAmbitions in worldTurn.ts apply real stat damage to the
  // named rival on success, not just to the faction that committed to it.
  targetFactionId String?
  targetFaction   Faction? @relation("FactionTargetedClocks", fields: [targetFactionId], references: [id], onDelete: SetNull)

  // Phase 9: NPC society — set when two allied major NPCs are jointly
  // pursuing this clock (see npcSocietyTick.ts). Deliberately NOT
  // sourceFactionId even when both NPCs share a faction: sourceFactionId
  // opts a clock OUT of the generic completion narration in
  // checkAndResolveCompletedClocks (it expects the ambition-specific
  // resolver in worldTurn.ts to handle it instead), and a joint scheme has
  // no such resolver — it wants the generic path.
  participantNpcIds String[] @default([])

  // #13 / universal front-style threats: a front (template-authored or
  // AI-generated, see campaign-templates.ts's FrontTemplate and
  // worldGenerator.ts's GeneratedFront) may concern a real faction WITHOUT
  // being that faction's tracked ambition. Same reasoning as
  // participantNpcIds above — deliberately separate from sourceFactionId
  // so a front's completion routes through the generic checkAndResolve-
  // CompletedClocks path (a public flavor-text event) instead of
  // resolveCompletedAmbitions, which expects a real PendingAmbition and
  // would otherwise misapply faction stat deltas to an unrelated front.
  relatedFactionId String?
  relatedFaction   Faction? @relation("FactionRelatedClocks", fields: [relatedFactionId], references: [id], onDelete: SetNull)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([targetFactionId])
  @@index([sourceFactionId])
}

//
// SCENES — FULL feature version
//

model Scene {
  id                  String      @id @default(cuid())
  campaignId          String
  sceneNumber         Int
  title               String?
  sceneIntroText      String      @db.Text // required by createNewScene()
  framing             String?     @db.Text // optional alternative, preserved
  location            String?
  participants        Json?
  status              SceneStatus @default(AWAITING_ACTIONS)
  sceneResolutionText String?     @db.Text

  // PbtA scene tracking
  sceneType String? @default("dramatic") // "dramatic", "downtime", "combat"
  stakes    String? // What's at risk in this scene

  // Phase 16: Freeform Combat & Exchange System
  combatMode      String? @default("freeform") // "freeform", "structured"
  exchangeState   Json? // { playersActed: string[], exchangeNumber: number, isComplete: boolean, complexity: 'simple' | 'complex' }
  currentExchange Int     @default(0)

  // Phase 14: Consequence tracking per scene
  consequences Json? // { created?: string[], resolved?: string[], relationshipChanges?: object[] }

  // Phase 9: Turn tracking
  turnDeadline   DateTime?
  waitingOnUsers Json? // Array of user IDs who need to act

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  playerActions PlayerAction[]
  diceRolls     DiceRoll[]
  turnOrder     TurnOrder?
  gmClarifications GmClarification[]

  // Phase 8: Communication
  messages Message[]    @relation("SceneMessages")
  notes    PlayerNote[] @relation("SceneNotes")

  // Phase 9: Notifications
  notifications Notification[] @relation("SceneNotifications")
  turnTracker   TurnTracker[]  @relation("SceneTurnTracker")

  @@index([campaignId])
  @@index([status])
}

//
// PLAYER ACTIONS
//

model PlayerAction {
  id            String  @id @default(cuid())
  sceneId       String
  characterId   String
  userId        String
  actionText    String  @db.Text
  intentOutcome String?
  status        String  @default("pending")
  resolution    String? @db.Text
  rollResult    Json?

  // PbtA move tracking
  moveUsed     String? // Which move was triggered
  rollRequired Boolean @default(false) // Does this need a roll?
  rollMade     String? // Link to DiceRoll.id if rolled

  // Phase 16: Exchange tracking
  exchangeNumber Int? // Which exchange this action belongs to
  actionPriority Int? @default(0) // For complex exchange ordering

  createdAt DateTime @default(now())

  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sceneId])
  @@index([characterId])
}

//
// GM CLARIFICATIONS — out-of-character Q&A, deliberately NOT a PlayerAction
//
// "Ask the GM" is a meta channel: a player clarifying the fiction before
// committing to a real action ("what can I see on this person?"), answered
// from the same fog-of-war-safe knowledge the AI narrator has, but never
// treated as something that happens in the story. It must never become a
// PlayerAction row — that would make it eligible for dice classification
// (resolveActionMechanics blindly processes every pending PlayerAction) and
// exchange-completion counting (ExchangeManager). See lib/ai/askGm.ts.
model GmClarification {
  id          String   @id @default(cuid())
  campaignId  String
  sceneId     String
  characterId String
  userId      String
  question    String   @db.Text
  answer      String   @db.Text
  createdAt   DateTime @default(now())

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([sceneId])
}

//
// TIMELINE — FULL feature version
//

model TimelineEvent {
  id            String          @id @default(cuid())
  campaignId    String
  turnNumber    Int? // required by world turn + UI
  title         String
  summaryPublic String?         @db.Text
  summaryGM     String?         @db.Text
  isOffscreen   Boolean?        @default(false)
  eventType     EventType?
  visibility    EventVisibility @default(PUBLIC)
  sessionDate   DateTime        @default(now())
  gmNotes       String?
  createdAt     DateTime        @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([turnNumber])
}

//
// WORLD META — FULL feature version
//

model WorldMeta {
  id                String   @id @default(cuid())
  campaignId        String   @unique
  currentTurnNumber Int      @default(1)
  currentInGameDate String?
  currentLocation   String?
  tension           Int      @default(50)
  phase             String?
  otherMeta         Json?
  gmNotes           String?
  updatedAt         DateTime @updatedAt

  // World-turn pacing: the faction/NPC simulation advances with IN-GAME
  // time, not per player action. hoursSinceWorldTurn accumulates the AI's
  // time_passage each resolution; a world turn runs once it crosses
  // worldTurnHours (null = default, see lib/game/tick/pacing.ts).
  hoursSinceWorldTurn Float @default(0)
  worldTurnHours      Int?

  // World Sim Phase 8: per-tick simulation caps (how many factions/NPCs the
  // tick handlers simulate each turn — see src/lib/game/tick/caps.ts).
  // Null means "use the default" (10/20) — most campaigns never need to
  // touch this; it exists for campaigns whose faction/NPC count grows past
  // the defaults and the admin wants the tick to cover more of them.
  factionCap Int?
  npcCap     Int?

  // Phase 15: AI Health & Cost Tracking
  aiHealth              Json? // Circuit breaker state and AI failure tracking
  aiMetrics             Json? // Token usage, costs, response times
  campaignHealthHistory Json? // Historical health scores and issues
  lastHealthCheck       DateTime? // Last time health was checked
  currentHealthScore    Int? // Current campaign health (0-100)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

//
// INVITES
//

model CampaignInvite {
  id         String   @id @default(cuid())
  campaignId String
  token      String   @unique @default(cuid())
  createdBy  String
  expiresAt  DateTime
  maxUses    Int      @default(0)
  uses       Int      @default(0)
  createdAt  DateTime @default(now())

  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdByUser User     @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([campaignId])
}

//
// PHASE 7 ADDITIONS: PbtA System
//

model Move {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  trigger     String // "When you..."
  description String   @db.Text
  rollType    String? // "roll+cool", "roll+hard", "act under fire", null for no roll
  outcomes    Json // {success: "...", partial: "...", miss: "..."}
  category    String   @default("basic") // "basic", "special", "custom"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  diceRolls DiceRoll[]

  @@index([campaignId])
}

model DiceRoll {
  id          String  @id @default(cuid())
  campaignId  String
  sceneId     String?
  characterId String
  userId      String

  rollType String // "move", "custom", "help", "interfere"
  moveId   String? // If rolling a specific move

  dice     Int[] // [6, 4] for 2d6 showing 6 and 4
  modifier Int   @default(0) // Stat modifier or forward
  total    Int // Sum of dice + modifier

  outcome     String // "strongHit" (10+), "weakHit" (7-9), "miss" (6-)
  description String? // Context for the roll

  forward Int? @default(0) // +1 forward granted
  ongoing Int? @default(0) // +1 ongoing granted
  hold    Int? @default(0) // Hold generated

  isSecret  Boolean  @default(false) // Hidden from other players
  createdAt DateTime @default(now())

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  scene     Scene?    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  move      Move?     @relation(fields: [moveId], references: [id])

  @@index([campaignId])
  @@index([sceneId])
  @@index([characterId])
}

model TurnOrder {
  id      String @id @default(cuid())
  sceneId String @unique

  // JSON array of {characterId, initiative, hasActed}
  order Json // [{characterId: "...", initiative: 12, hasActed: false}]

  currentTurn Int     @default(0) // Index in the order array
  roundNumber Int     @default(1)
  isActive    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scene      Scene       @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  characters Character[]

  @@index([sceneId])
}

//
// PHASE 8: COMMUNICATION MODELS
//

model Message {
  id         String      @id @default(cuid())
  content    String      @db.Text
  type       MessageType @default(OUT_OF_CHARACTER)
  authorId   String
  campaignId String
  sceneId    String?

  // For whisper/private messages
  targetUserId String?

  // Character context (for IC messages)
  characterId String?

  // Phase 9: Mention detection
  mentionsUserIds Json?   @default("[]")
  hasMentions     Boolean @default(false)

  // Phase 9: Sound triggers
  triggerSound String?
  soundVolume  Float?  @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  author     User       @relation("UserMessages", fields: [authorId], references: [id], onDelete: Cascade)
  targetUser User?      @relation("UserWhispers", fields: [targetUserId], references: [id], onDelete: Cascade)
  campaign   Campaign   @relation("CampaignMessages", fields: [campaignId], references: [id], onDelete: Cascade)
  scene      Scene?     @relation("SceneMessages", fields: [sceneId], references: [id], onDelete: Cascade)
  character  Character? @relation("CharacterMessages", fields: [characterId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([campaignId, sceneId])
  @@map("messages")
}

model PlayerNote {
  id         String         @id @default(cuid())
  title      String
  content    String         @db.Text
  visibility NoteVisibility @default(PRIVATE)
  authorId   String
  campaignId String

  // Optional associations
  characterId String?
  npcId       String?
  factionId   String?
  sceneId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  author    User       @relation("UserNotes", fields: [authorId], references: [id], onDelete: Cascade)
  campaign  Campaign   @relation("CampaignNotes", fields: [campaignId], references: [id], onDelete: Cascade)
  character Character? @relation("CharacterNotes", fields: [characterId], references: [id], onDelete: Cascade)
  npc       NPC?       @relation("NPCNotes", fields: [npcId], references: [id], onDelete: Cascade)
  faction   Faction?   @relation("FactionNotes", fields: [factionId], references: [id], onDelete: Cascade)
  scene     Scene?     @relation("SceneNotes", fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([campaignId, authorId])
  @@index([campaignId, visibility])
  @@map("player_notes")
}

//
// PHASE 9: NOTIFICATION MODELS
//

model Notification {
  id       String               @id @default(cuid())
  type     NotificationType
  title    String
  message  String               @db.Text
  status   NotificationStatus   @default(UNREAD)
  priority NotificationPriority @default(NORMAL)

  // Recipients
  userId     String
  campaignId String?
  sceneId    String?

  // Metadata for rich notifications
  actionUrl String?
  metadata  Json?

  // Email/Push settings
  emailSent Boolean @default(false)
  pushSent  Boolean @default(false)

  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  readAt      DateTime?
  dismissedAt DateTime?

  // Relationships
  user     User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation("CampaignNotifications", fields: [campaignId], references: [id], onDelete: Cascade)
  scene    Scene?    @relation("SceneNotifications", fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([campaignId, type])
  @@index([createdAt])
  @@map("notifications")
}

model UserNotificationSettings {
  id     String @id @default(cuid())
  userId String @unique

  // Email notification preferences
  emailEnabled         Boolean @default(true)
  emailTurnReminders   Boolean @default(true)
  emailSceneChanges    Boolean @default(true)
  emailMentions        Boolean @default(true)
  emailWhispers        Boolean @default(true)
  emailCampaignInvites Boolean @default(true)
  emailWorldEvents     Boolean @default(false)

  // Browser push notification preferences
  pushEnabled         Boolean @default(true)
  pushTurnReminders   Boolean @default(true)
  pushSceneChanges    Boolean @default(true)
  pushMentions        Boolean @default(true)
  pushWhispers        Boolean @default(true)
  pushCampaignInvites Boolean @default(true)

  // Sound notification preferences
  soundEnabled         Boolean @default(true)
  soundTurnReminders   Boolean @default(true)
  soundSceneChanges    Boolean @default(true)
  soundMentions        Boolean @default(true)
  soundWhispers        Boolean @default(true)
  soundCriticalMoments Boolean @default(true)
  soundWorldEvents     Boolean @default(true)

  // Timing preferences
  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String? // "22:00"
  quietHoursEnd     String? // "08:00"
  timezone          String? // "America/New_York"

  // Digest preferences
  dailyDigestEnabled  Boolean @default(false)
  weeklyDigestEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user User @relation("UserNotificationSettings", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_settings")
}

model TurnTracker {
  id         String  @id @default(cuid())
  campaignId String
  sceneId    String?

  // Turn order and timing
  currentTurn        Int       @default(0)
  turnOrder          Json // Array of character/player IDs
  turnStartedAt      DateTime?
  turnDeadline       DateTime?
  autoAdvanceTurn    Boolean   @default(false)
  turnTimeoutMinutes Int       @default(60)

  // Notifications sent
  remindersSent    Json      @default("[]") // Array of timestamps
  lastReminderSent DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  campaign Campaign @relation("CampaignTurnTracker", fields: [campaignId], references: [id], onDelete: Cascade)
  scene    Scene?   @relation("SceneTurnTracker", fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sceneId])
  @@map("turn_trackers")
}

//
// PHASE 10.5: AI VISUAL GENERATION MODELS
//

model Map {
  id          String   @id @default(cuid())
  campaignId  String
  sceneId     String?
  name        String
  description String?  @db.Text
  width       Int      @default(800)
  height      Int      @default(600)
  gridSize    Int      @default(40)
  background  String? // Color or image URL
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zones  Zone[]
  tokens Token[]

  @@index([campaignId])
  @@index([sceneId])
  @@map("maps")
}

model Zone {
  id          String  @id @default(cuid())
  mapId       String
  name        String
  description String? @db.Text
  x           Int
  y           Int
  width       Int
  height      Int
  color       String? @default("#3b82f6")
  isActive    Boolean @default(true)
  metadata    Json? // For additional properties

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("zones")
}

model Token {
  id        String  @id @default(cuid())
  mapId     String
  name      String
  x         Int
  y         Int
  color     String  @default("#ef4444")
  size      Int     @default(30)
  isPlayer  Boolean @default(false)
  isVisible Boolean @default(true)
  metadata  Json? // For character ID, NPC ID, etc.

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("tokens")
}

//
// PHASE 11: SESSION & DOWNTIME MODELS
//

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ActivityStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

model Session {
  id                String        @id @default(cuid())
  campaignId        String
  name              String
  description       String?       @db.Text
  sessionNumber     Int
  status            SessionStatus @default(SCHEDULED)
  scheduledAt       DateTime?
  startTime         DateTime? // Keep for compatibility
  startedAt         DateTime? // Add for service compatibility
  endTime           DateTime? // Keep for compatibility
  endedAt           DateTime? // Add for service compatibility
  duration          Int? // In minutes
  objectives        String[]
  experienceAwarded Int           @default(0)
  goldAwarded       Int           @default(0)
  itemsAwarded      String[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  participants SessionParticipant[]
  scenes       SessionScene[]
  notes        SessionNote[]

  @@index([campaignId])
  @@index([status])
  @@map("sessions")
}

model SessionParticipant {
  id               String    @id @default(cuid())
  sessionId        String
  characterId      String
  userId           String
  joinedAt         DateTime  @default(now())
  leftAt           DateTime?
  wasPresent       Boolean   @default(true)
  attendanceStatus String    @default("PRESENT") // PRESENT, ABSENT, LATE, LEFT_EARLY
  actionsCount     Int       @default(0)
  messagesCount    Int       @default(0)
  notes            String?   @db.Text

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, characterId])
  @@index([sessionId])
  @@map("session_participants")
}

model SessionScene {
  id         String    @id @default(cuid())
  sessionId  String
  sceneId    String
  orderIndex Int
  duration   Int? // In minutes
  summary    String?   @db.Text
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  notes      String?   @db.Text

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_scenes")
}

model SessionNote {
  id        String   @id @default(cuid())
  sessionId String
  authorId  String
  content   String   @db.Text
  noteType  String   @default("general") // general, highlight, decision, npc
  isPublic  Boolean  @default(true)
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_notes")
}

model DowntimeActivity {
  id          String         @id @default(cuid())
  characterId String
  description String         @db.Text // Natural language description
  summary     String         @db.Text // AI-generated summary
  status      ActivityStatus @default(ACTIVE)

  // AI-determined properties
  estimatedDays  Int
  currentDay     Int      @default(0)
  costs          Json? // {gold: 100, resources: [...]}
  requirements   String[] // Prerequisites
  skillsInvolved String[] // Skills being used
  riskLevel      String? // low, medium, high

  outcomes     Json? // Potential outcomes
  finalOutcome String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  events DowntimeEvent[]

  @@index([characterId])
  @@index([status])
  @@map("downtime_activities")
}

model DowntimeEvent {
  id          String    @id @default(cuid())
  activityId  String
  dayNumber   Int
  eventText   String    @db.Text // AI-generated event
  choices     Json? // Available choices
  response    String?   @db.Text // Player response
  outcome     String?   @db.Text // Result of response
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  activity DowntimeActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("downtime_events")
}

//
// PHASE 16.5: TUTORIAL & ONBOARDING
//

enum TutorialStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model TutorialStep {
  id            String   @id @default(cuid())
  stepKey       String   @unique // e.g., "create_character", "first_action"
  title         String
  description   String   @db.Text
  category      String // "basics", "combat", "social", "advanced"
  orderIndex    Int
  isOptional    Boolean  @default(false)
  prerequisites String[] // Array of stepKeys that must be completed first

  // Interactive tutorial data
  contentBlocks   Json? // Array of content blocks with type, text, images
  targetElement   String? // CSS selector for highlighting
  tooltipPosition String? @default("bottom") // top, bottom, left, right

  // Completion criteria
  completionTrigger String? // e.g., "submit_action", "create_character"
  validationRules   Json? // Rules to check if step is complete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userProgress UserTutorialProgress[]

  @@index([category, orderIndex])
  @@map("tutorial_steps")
}

model UserTutorialProgress {
  id          String         @id @default(cuid())
  userId      String
  stepId      String
  status      TutorialStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  skippedAt   DateTime?

  // User's interaction data
  attemptsCount Int @default(0)
  hintsViewed   Int @default(0)
  timeSpent     Int @default(0) // In seconds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  step TutorialStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([userId, stepId])
  @@index([userId, status])
  @@map("user_tutorial_progress")
}

model CampaignTutorialMode {
  id         String  @id @default(cuid())
  campaignId String  @unique
  isEnabled  Boolean @default(true)

  // Tutorial campaign settings
  useGuidedScenes Boolean @default(true)
  showTooltips    Boolean @default(true)
  provideHints    Boolean @default(true)
  allowSkip       Boolean @default(true)

  // Progress tracking
  currentStepKey String?
  completedSteps String[] // Array of stepKeys

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("campaign_tutorial_mode")
}

//
// PHASE 25: SAFETY TOOLS & CONTENT MODERATION
//

enum ContentWarningType {
  VIOLENCE
  SEXUAL_CONTENT
  GORE
  HORROR
  SUBSTANCE_ABUSE
  MENTAL_HEALTH
  DISCRIMINATION
  DEATH
  TRAUMA
  CUSTOM
}

enum XCardTrigger {
  SCENE_CONTENT
  MESSAGE
  CHARACTER_ACTION
  NPC_BEHAVIOR
  GENERAL
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CampaignSafetySettings {
  id         String @id @default(cuid())
  campaignId String @unique

  // X-Card settings
  xCardEnabled      Boolean @default(true)
  anonymousXCard    Boolean @default(true) // Don't show who used X-Card
  pauseOnXCard      Boolean @default(true)
  xCardNotifyGMOnly Boolean @default(false)

  // Content warnings
  contentWarningsEnabled Boolean @default(true)
  activeWarnings         Json    @default("[]") // Array of ContentWarningType

  // Lines and Veils (pre-game safety discussion)
  lines String[] // Hard boundaries - will not be included
  veils String[] // Soft boundaries - will be implied, not detailed

  // Session Zero settings
  sessionZeroCompleted Boolean   @default(false)
  sessionZeroDate      DateTime?
  sessionZeroNotes     String?   @db.Text

  // Content moderation
  autoModeration  Boolean @default(false)
  moderationLevel String  @default("medium") // low, medium, high

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("campaign_safety_settings")
}

model XCardUse {
  id         String  @id @default(cuid())
  campaignId String
  sceneId    String?
  userId     String

  trigger     XCardTrigger
  targetId    String? // ID of message, action, scene, etc.
  reason      String?      @db.Text // Optional explanation
  isAnonymous Boolean      @default(true)

  // GM/Moderator response
  acknowledged   Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolution     String?   @db.Text

  createdAt DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([sceneId])
  @@map("x_card_uses")
}

model ContentReport {
  id         String @id @default(cuid())
  reporterId String
  campaignId String

  // What's being reported
  contentType String // "message", "note", "character", "scene", "user_behavior"
  contentId   String?
  contentText String? @db.Text

  reason   String         @db.Text
  category String? // harassment, inappropriate_content, cheating, other
  severity ReportSeverity @default(MEDIUM)
  status   ReportStatus   @default(PENDING)

  // Moderation
  reviewedBy  String?
  reviewedAt  DateTime?
  resolution  String?   @db.Text
  actionTaken String? // warning, content_removed, user_banned, dismissed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, status])
  @@index([reporterId])
  @@index([status, severity])
  @@map("content_reports")
}

model UserBlock {
  id            String  @id @default(cuid())
  userId        String // User doing the blocking
  blockedUserId String // User being blocked
  campaignId    String? // Optional: block only in specific campaign
  reason        String? @db.Text

  createdAt DateTime @default(now())

  @@unique([userId, blockedUserId, campaignId])
  @@index([userId])
  @@index([blockedUserId])
  @@map("user_blocks")
}

model CampaignBan {
  id          String    @id @default(cuid())
  campaignId  String
  userId      String
  bannedBy    String // GM/Admin who issued the ban
  reason      String    @db.Text
  isPermanent Boolean   @default(false)
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  @@unique([campaignId, userId])
  @@index([userId])
  @@map("campaign_bans")
}

//
// PAYMENT & TRANSACTION TRACKING
//

enum TransactionType {
  CREDIT // User added funds
  DEBIT // AI usage charge
  REFUND // Refund issued
  ADJUSTMENT // Manual adjustment
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  type          TransactionType
  amount        Int // In cents (positive for credit, negative for debit)
  balanceBefore Int // Balance before transaction
  balanceAfter  Int // Balance after transaction
  description   String
  metadata      Json? // Additional info (e.g., sceneId, tokens used, etc.)
  createdAt     DateTime        @default(now())

  @@index([userId, createdAt])
  @@map("transactions")
}

//
// CAMPAIGN LOG & PROGRESSION TRACKING
//

model CampaignLog {
  id         String  @id @default(cuid())
  campaignId String
  sceneId    String? // Optional link to specific scene
  turnNumber Int

  // Content
  title      String
  summary    String   @db.Text // AI-generated summary of what happened
  highlights String[] // Key events or important moments
  entryType  String   @default("scene") // scene, downtime, world_event, milestone

  // Timeline tracking
  inGameDate String? // Optional in-game date/time
  duration   String? // How much in-game time passed (e.g., "2 hours", "3 days")

  createdAt DateTime @default(now())

  @@index([campaignId, turnNumber])
  @@index([sceneId])
  @@map("campaign_logs")
}

//
// CAMPAIGN WIKI & KNOWLEDGE BASE
//

enum WikiEntryType {
  NPC
  FACTION
  LOCATION
  CLOCK
  ITEM
  QUEST
  LORE
  CUSTOM
}

model WikiEntry {
  id         String        @id @default(cuid())
  campaignId String
  entryType  WikiEntryType

  // Basic info
  name        String
  summary     String @db.Text // Short description
  description String @db.Text // Full details

  // Metadata
  tags     String[] // For filtering/searching
  aliases  String[] // Alternative names
  imageUrl String? // Optional image

  // Relationships
  relatedEntries Json? // Array of {id, type, relationship} to link entries

  // Status tracking
  isActive     Boolean @default(true)
  lastSeenTurn Int? // Last turn this was mentioned/updated
  importance   String  @default("normal") // minor, normal, major, critical

  // History
  changelog Json? // Array of {turn, change, summary} for tracking updates

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String   @default("ai") // ai or userId

  @@index([campaignId, entryType])
  @@index([campaignId, name])
  @@index([campaignId, isActive])
  @@map("wiki_entries")
}

//
// CAMPAIGN MEMORY & RAG SYSTEM
//

enum MemoryType {
  SCENE
  NPC_INTERACTION
  FACTION_EVENT
  LOCATION_EVENT
  CHARACTER_MOMENT
  CLOCK_COMPLETION
  WORLD_EVENT
}

enum MemoryImportance {
  MINOR
  NORMAL
  MAJOR
  CRITICAL
}

model CampaignMemory {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // What this memory is about
  memoryType MemoryType
  sourceId   String // ID of source (sceneId, npcId, factionId, etc.)
  turnNumber Int

  // Searchable content
  title       String
  summary     String @db.Text // 2-3 sentence summary
  fullContext String @db.Text // Full scene resolution or event description

  // Vector embedding (pgvector type)
  // Using Unsupported because Prisma doesn't have built-in vector support yet
  embedding Unsupported("vector(1536)")? // OpenAI ada-002 produces 1536 dimensions

  // Entity tracking (for targeted retrieval)
  involvedCharacterIds String[] @default([])
  involvedNpcIds       String[] @default([])
  involvedFactionIds   String[] @default([])
  locationTags         String[] @default([])

  // Importance weighting
  importance    MemoryImportance @default(NORMAL)
  emotionalTone String? // "tense", "triumphant", "tragic", etc.
  tags          String[]         @default([]) // ["combat", "betrayal", "alliance", etc.]

  createdAt DateTime @default(now())

  @@index([campaignId, turnNumber])
  @@index([campaignId, memoryType])
  @@index([campaignId, importance])
  @@map("campaign_memories")
}

//
// LORE IMPORT — reference material (pasted text, a URL, or an entire wiki)
// chunked and embedded the same way CampaignMemory is, but for static
// world-bible content rather than "things that happened in play". See
// lib/lore/ (collection + chunking) and lib/ai/loreRetrieval.ts (semantic
// search, mirrors memoryRetrieval.ts).
//

enum LoreSourceType {
  PASTE
  URL
  WIKI
}

enum LoreImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model LoreImportJob {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  sourceType  LoreSourceType
  sourceUrl   String? // for URL / WIKI
  sourceTitle String? // display name shown in the admin UI
  rawText     String? @db.Text // for PASTE

  status   LoreImportJobStatus @default(PENDING)
  attempts Int                 @default(0)
  lastError String?

  // Set once a global stuck-job sweep (lib/jobs/stuckJobAlert.ts) has fired
  // an alert for this job — see the identical field on ResolutionJob.
  alertedStuckAt DateTime?

  // Set when the campaign was created WITH this lore source: on completion
  // the worker automatically reseeds the world from the imported canon
  // (lib/lore/reseedWorld.ts) instead of waiting for the admin button.
  // While such a job is in flight the campaign is unplayable — see
  // Campaign.pendingWorldSeed.
  autoReseedOnComplete Boolean @default(false)

  // Progress, shown to the admin while a wiki crawl is running.
  pagesFound     Int @default(0)
  pagesDone      Int @default(0)
  entriesCreated Int @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  entries LoreEntry[]

  @@index([campaignId, status])
}

model LoreEntry {
  id         String        @id @default(cuid())
  campaignId String
  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  jobId      String
  job        LoreImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  title     String
  sourceUrl String? // the specific page this chunk came from, for WIKI/URL sources
  content   String  @db.Text // one chunk — see lib/lore/textChunker.ts

  embedding Unsupported("vector(1536)")?

  tags String[] @default([])

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([jobId])
  @@map("lore_entries")
}

//
// WORLD SIM — PERSISTED EVENT STREAM
//
// Every deterministic tick change and player-action consequence gets written
// here, not just the "significant" ones (those additionally get written to
// CampaignMemory for RAG, and trigger a WikiEntry refresh — this table is
// the durable, structured record all of that already derives from). Future
// systems (rumors, economy, analytics, recaps) read from this table instead
// of coupling directly to the simulation systems that produced the events.

model WorldEvent {
  id         String   @id @default(cuid())
  campaignId String
  turnNumber Int
  createdAt  DateTime @default(now())

  // A short, filterable key: "<targetType>.<field>", e.g. "faction.resources",
  // "npc.currentPlan", "location_weather.weather"
  type   String
  origin String // "tick" | "consequence" — mirrors WorldChange.origin

  actorType WorldEventActorType @default(SYSTEM)
  // No per-character attribution yet — consequence extraction operates on
  // scene text as a whole, not per-player-action, so PLAYER events can't be
  // pinned to a specific user/character today. actorId stays null until
  // that's threaded through.
  actorId   String?

  targetType WorldEventTargetType
  targetId   String
  targetName String

  field         String
  previousValue String?
  newValue      String?

  reason      String  @db.Text
  significant Boolean @default(false)
  importance  String  @default("NORMAL") // "NORMAL" | "MAJOR"

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, turnNumber])
  @@index([campaignId, targetType, targetId])
  @@index([campaignId, type])
  @@map("world_events")
}

//
// RATE LIMITING
//
// Fixed-window request counters for the AI-invoking routes (see
// src/lib/rateLimit.ts). Postgres-backed rather than in-memory because the
// app deploys to serverless, where each instance has its own memory — a
// counter that only one lambda can see limits nothing. Rows are pruned
// opportunistically as new windows open.

model RateLimitCounter {
  id          String   @id @default(cuid())
  key         String // "<userId>:<bucket>"
  windowStart DateTime
  count       Int      @default(1)

  @@unique([key, windowStart])
  @@index([windowStart])
}

//
// FRIENDS SYSTEM
//

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  message    String?             @db.Text // Optional message with the request

  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId])
  @@map("friend_requests")
}

model Friendship {
  id      String @id @default(cuid())
  user1Id String // Lower ID alphabetically for consistency
  user2Id String // Higher ID alphabetically

  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("friendships")
}

//
// ASYNC SCENE RESOLUTION
//
// Scene resolution (AI GM call + world turn) can take ~150s — longer than
// a request handler should live. Action submission enqueues a job here
// and returns immediately; a dedicated internal route processes it in its
// own invocation, with the existing Pusher events (scene:resolving /
// scene:resolved / scene:resolution-failed) carrying progress to the UI.
// Stale jobs are recovered opportunistically by scene GET traffic.
//

enum ResolutionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ResolutionJob {
  id         String              @id @default(cuid())
  campaignId String
  sceneId    String
  status     ResolutionJobStatus @default(PENDING)
  attempts   Int                 @default(0)
  lastError  String?

  // Set once a global stuck-job sweep (lib/jobs/stuckJobAlert.ts) has fired
  // an alert for this job, so a dead job gets reported exactly once instead
  // of on every sweep. Cleared implicitly by the job leaving PENDING/RUNNING.
  alertedStuckAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([sceneId, status])
  @@index([campaignId, status])
}

model AIValidationFailure {
  id           String   @id @default(cuid())
  campaignId   String
  sceneId      String?
  errorSummary String // Short description of what failed
  rawResponse  Json? // The AI output that failed validation
  zodErrors    Json // Serialised ZodError.errors array
  createdAt    DateTime @default(now())

  @@index([campaignId])
  @@index([createdAt])
  @@map("ai_validation_failures")
}

//
// ALPHA INSTRUMENTATION (#12) — funnel/retention events
//
// A deliberately loose-coupled event log: no FK relations to User/Campaign,
// so recording an event can never fail on a constraint and a deleted
// entity's historical events still count toward that day's funnel numbers.
// See lib/analytics/events.ts for the writer and the dashboard queries.

enum AnalyticsEventType {
  SIGNUP
  CAMPAIGN_CREATED
  CHARACTER_CREATED
  SCENE_STARTED
  ACTION_SUBMITTED
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  type       AnalyticsEventType
  userId     String?
  campaignId String?
  metadata   Json?
  createdAt  DateTime           @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}
