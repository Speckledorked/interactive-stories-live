# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# JWT Authentication
JWT_SECRET="your-secret-key-change-me"

# OpenAI API (for AI GM features)
OPENAI_API_KEY="sk-..."

# Pusher (for real-time updates)
# Server-side Pusher config
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="your-pusher-cluster"

# Client-side Pusher config (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="your-pusher-cluster"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP Email Configuration (for notifications and invites)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# AI Debug Mode
AI_DEBUG_MODE="false"

# Platform admin analytics dashboard (/admin/analytics) — comma-separated
# email allowlist. Leave unset to disable the dashboard for everyone.
PLATFORM_ADMIN_EMAILS="you@example.com"

# Secures the internal worker routes (async scene resolution, lore import
# jobs) that self-invoke over HTTP — see lib/game/resolutionQueue.ts. Falls
# back to JWT_SECRET if unset, but set a dedicated value in production.
INTERNAL_JOB_SECRET="change-me-to-a-random-string"

# Secures the daily cron sweep (vercel.json's `crons`, api/internal/cron/
# world-tick-sweep) — Vercel automatically sends this as
# `Authorization: Bearer $CRON_SECRET` when invoking cron jobs. Required
# for the world tick to advance without a player driving traffic.
CRON_SECRET="change-me-to-a-random-string"

# Stripe (for payment processing)
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
